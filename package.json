{
  "name": "soiree-website",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && cp dist/index.html dist/404.html && touch dist/.nojekyll",
    "preview": "vite preview",
    "deploy": "npm run build && gh-pages -d dist -r https://github.com/soiree-hk/soiree.git",
    "scrape": "node scripts/scrape-all-posts.mjs",
    "download-images": "node scripts/download-images.mjs"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "gh-pages": "^6.3.0",
    "vite": "^6.0.0"
  }
}
